# ─── Model Config ─────────────────────────────────────────────────────────────
# Which Ollama model to use. Options: mistral, llama3, llama3:8b, phi3, gemma
MODEL=mistral

# Ollama server URL (same machine = 127.0.0.1)
OLLAMA_URL=http://127.0.0.1:11434

# ─── Auth ─────────────────────────────────────────────────────────────────────
# From your RapidAPI provider dashboard → Security tab (fill after listing)
RAPIDAPI_PROXY_SECRET=your-rapidapi-proxy-secret

# For direct API access without RapidAPI (testing / own apps)
# Leave blank to disable direct access
DIRECT_API_KEY=your-secret-key-here

# ─── Limits ───────────────────────────────────────────────────────────────────
# Max requests per user per minute
RATE_LIMIT_RPM=20

# Server port (Render sets automatically)
PORT=3000
