{
  "name": "smartchat-api",
  "version": "1.0.0",
  "description": "Self-hosted conversational AI API — Mistral 7B via Ollama, zero AI API costs",
  "main": "server.js",
  "scripts": {
    "start": "bash start.sh",
    "dev": "ollama serve & sleep 3 && ollama pull mistral && nodemon server.js",
    "api-only": "node sserver.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": ["chatbot", "ai", "mistral", "ollama", "self-hosted", "rapidapi"],
  "license": "MIT"
}
